{
  "manifest_version": 3,
  "name": "Hoverbar",
  "version": "0.1.5",
  "description": "A hover-revealed overlay bar for Firefox Bookmarks Toolbar items.",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "theme"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "48": "icons/hoverbar.svg",
    "96": "icons/hoverbar.svg"
  },
  "action": {
    "default_title": "Hoverbar",
    "default_popup": "options.html",
    "default_icon": {
      "48": "icons/hoverbar.svg",
      "96": "icons/hoverbar.svg"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "chrome_settings_overrides": {
    "homepage": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "match_about_blank": true,
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "overlay.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "hoverbar-extension@aloglu.github.io",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}
